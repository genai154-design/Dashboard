# Tavily API 키
# 로컬: copy .env.example .env 후 키 입력
# Vercel: Dashboard → Settings → Environment Variables

TAVILY_API_KEY=tvly-your-api-key-here

# Exchange Rate API 키 (선택)
# https://www.exchangerate-api.com/ 가입 후 이메일 인증 필수!
# inactive-account 오류 → 이메일 인증 미완료. 인증 전까지는 키 줄을 삭제하거나 주석 처리하세요.
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key-here

# 네이버 검색 API (Client ID / Client Secret)
# https://developers.naver.com/apps/#/list 에서 애플리케이션 등록 후 발급
# Vercel: NAVER_CLIENT_ID, NAVER_CLIENT_SECRET 각각 환경 변수로 설정
NAVER_CLIENT_ID=your-naver-client-id-here
NAVER_CLIENT_SECRET=your-naver-client-secret-here

# Google AI Studio Gemini API 키
# https://aistudio.google.com/apikey 에서 발급
# Vercel: GEMINI_API_KEY 환경 변수로 설정
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini 모델 ID (선택, 기본값: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# AI 프롬프트 폴더 (선택, 기본값: prompt/)
# PROMPT_DIR=prompt

# 로컬 Express 서버 포트 (선택)
PORT=3000
